          <li>Basado en PPTs de tu universidad</li>
        </ul>
      </article>

      <!-- Card 2 -->
      <article class="card">
        <div class="header">
          <div class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" aria-hidden="true">
  <rect x="4"  y="12" width="3" height="8"/>
  <rect x="10" y="9"  width="3" height="11"/>
  <rect x="16" y="6"  width="3" height="14"/>
</svg>

          </div>
